# Environment variables for xBrain configuration
LANGUAGE="Ukrainian"

# Enable self-development mode for the Brain (default: false)
SELF_DEV_MODE=false

# Quality Command: composer test | composer analyse (default: composer test)
# QUALITY_COMMAND_TEST="composer test"
# QUALITY_COMMAND_PHPSTAN="composer analyse"

# Model Tier: economy | standard | premium (convenience alias)
# Maps to STRICT_MODE + COGNITIVE_LEVEL defaults. Explicit vars override.
# Usage: MODEL_TIER=premium scripts/tier-compile.sh
# MODEL_TIER="standard"

# Strict Mode: relaxed | standard | strict | paranoid (default: standard)
# STRICT_MODE="standard"

# Cognitive Level: minimal | standard | deep | exhaustive (default: standard)
# COGNITIVE_LEVEL="standard"

# Verbosity: minimal | low | medium | high | maximum (default: medium)
# VERBOSITY="medium"

# MCP Server Credentials (required for brain compile with MCP servers)
# GitHub Copilot MCP — personal access token (classic or fine-grained)
# GITHUB_MCP_TOKEN=""

# Context7 MCP — API key from https://upstash.com
# CONTEXT7_API_KEY=""
