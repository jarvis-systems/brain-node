# Environment variables for xBrain configuration
LANGUAGE="Ukrainian"

# Quality Command: composer test | composer analyse (default: composer test)
# QUALITY_COMMAND_TEST="composer test"
# QUALITY_COMMAND_PHPSTAN="composer analyse"

# Strict Mode: relaxed | standard | strict | paranoid (default: standard)
# STRICT_MODE="standard"

# Cognitive Level: minimal | standard | deep | exhaustive (default: standard)
# COGNITIVE_LEVEL="standard"

# Verbosity: minimal | low | medium | high | maximum (default: medium)
# VERBOSITY="medium"
